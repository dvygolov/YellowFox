<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:YellowFox.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="380"
        x:Class="YellowFox.Desktop.Views.ExtensionEditorWindow"
        x:DataType="vm:ExtensionEditorViewModel"
        Icon="/Assets/yellowfox.ico"
        Width="560" Height="390"
        MinWidth="520" MinHeight="360"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,24,0,0">
            <Button AutomationProperties.AutomationId="ExtensionEditorSaveButton"
                    Width="140" Height="42"
                    Click="SaveButton_Click"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                    <TextBlock Text="Save" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button AutomationProperties.AutomationId="ExtensionEditorCancelButton"
                    Width="140" Height="42"
                    Click="CancelButton_Click"
                    Background="#3E3E42"
                    Foreground="#CCCCCC"
                    BorderThickness="0"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                    <TextBlock Text="Cancel" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Spacing="14">
            <TextBlock Text="{Binding Title}" Foreground="#CCCCCC" FontSize="20" FontWeight="Bold" Margin="0,0,0,8" />

            <StackPanel Spacing="6">
                <TextBlock Text="Name *" Foreground="#CCCCCC" FontWeight="SemiBold" />
                <TextBox AutomationProperties.AutomationId="ExtensionNameInput"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Extension name"
                         Background="#1E1E1E"
                         Foreground="#CCCCCC"
                         BorderBrush="#3E3E42"
                         Padding="12,10"
                         CornerRadius="6" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Path *" Foreground="#CCCCCC" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                             AutomationProperties.AutomationId="ExtensionPathInput"
                             Text="{Binding ExtensionPath, UpdateSourceTrigger=PropertyChanged}"
                             Watermark="Folder with manifest.json, or .xpi/.zip file"
                             Background="#1E1E1E"
                             Foreground="#CCCCCC"
                             BorderBrush="#3E3E42"
                             Padding="12,10"
                             CornerRadius="6"
                             TextWrapping="NoWrap" />
                    <Button Grid.Column="1"
                            AutomationProperties.AutomationId="BrowseExtensionFileButton"
                            Content="File"
                            Click="BrowseFileButton_Click"
                            Padding="14,9"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="6" />
                    <Button Grid.Column="2"
                            AutomationProperties.AutomationId="BrowseExtensionFolderButton"
                            Content="Folder"
                            Click="BrowseFolderButton_Click"
                            Padding="14,9"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="6" />
                </Grid>
            </StackPanel>

            <CheckBox AutomationProperties.AutomationId="ExtensionEnabledCheckbox"
                      Content="Enabled"
                      IsChecked="{Binding IsExtensionEnabled}"
                      Foreground="#CCCCCC"
                      Margin="0,4,0,0" />
        </StackPanel>
    </DockPanel>
</Window>
