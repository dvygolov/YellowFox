<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:YellowFox.Desktop.ViewModels"
        xmlns:views="using:YellowFox.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="YellowFox.Desktop.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="YellowFox - Profile Manager"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="500"
        WindowState="Maximized">

    <DockPanel Background="#1E1E1E">
        <!-- Sidebar -->
        <Border DockPanel.Dock="Left" Width="200" BorderBrush="#3E3E42" BorderThickness="0,0,1,0" Background="#252526">
            <StackPanel Margin="15,20">
                <TextBlock Text="🦊 YellowFox" FontSize="18" FontWeight="Bold" Foreground="#CCCCCC" Margin="0,0,0,30" />
                
                <!-- Profiles -->
                <Button Content="📋 Profiles"
                        Command="{Binding ShowProfilesCommand}"
                        IsVisible="{Binding IsProfilesSection}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        FontWeight="SemiBold" />
                <Button Content="📋 Profiles"
                        Command="{Binding ShowProfilesCommand}"
                        IsVisible="{Binding IsNotProfilesSection}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Background="#2E3132"
                        Foreground="#CCCCCC"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left" />

                <!-- Proxies -->
                <Button Content="🌐 Proxies"
                        Command="{Binding ShowProxiesCommand}"
                        IsVisible="{Binding IsProxiesSection}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        FontWeight="SemiBold" />
                <Button Content="🌐 Proxies"
                        Command="{Binding ShowProxiesCommand}"
                        IsVisible="{Binding IsNotProxiesSection}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Background="#2E3132"
                        Foreground="#CCCCCC"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left" />

                <!-- Extensions -->
                <Button Content="🧩 Extensions"
                        Command="{Binding ShowExtensionsCommand}"
                        IsVisible="{Binding IsExtensionsSection}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        FontWeight="SemiBold" />
                <Button Content="🧩 Extensions"
                        Command="{Binding ShowExtensionsCommand}"
                        IsVisible="{Binding IsNotExtensionsSection}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="12,10"
                        Background="#2E3132"
                        Foreground="#CCCCCC"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left" />

                <!-- Bookmarks -->
                <Button Content="🔖 Bookmarks"
                        Command="{Binding ShowBookmarksCommand}"
                        IsVisible="{Binding IsBookmarksSection}"
                        HorizontalAlignment="Stretch"
                        Padding="12,10"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        FontWeight="SemiBold" />
                <Button Content="🔖 Bookmarks"
                        Command="{Binding ShowBookmarksCommand}"
                        IsVisible="{Binding IsNotBookmarksSection}"
                        HorizontalAlignment="Stretch"
                        Padding="12,10"
                        Background="#2E3132"
                        Foreground="#CCCCCC"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left" />
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <Grid>
            <views:ProfilesView DataContext="{Binding ProfilesViewModel}"
                                IsVisible="{Binding DataContext.IsProfilesSection, ElementName=RootWindow}" />
            <views:ProxiesView DataContext="{Binding ProxiesViewModel}"
                               IsVisible="{Binding DataContext.IsProxiesSection, ElementName=RootWindow}" />
            <views:ExtensionsView DataContext="{Binding ExtensionsViewModel}"
                                  IsVisible="{Binding DataContext.IsExtensionsSection, ElementName=RootWindow}" />
            <views:BookmarksView DataContext="{Binding BookmarksViewModel}"
                                 IsVisible="{Binding DataContext.IsBookmarksSection, ElementName=RootWindow}" />
        </Grid>
    </DockPanel>

</Window>
