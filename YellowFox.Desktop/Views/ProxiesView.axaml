<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:YellowFox.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:Class="YellowFox.Desktop.Views.ProxiesView"
             x:DataType="vm:ProxiesViewModel"
             Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Background="#2D2D2D"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="New"
                            AutomationProperties.AutomationId="NewProxyButton"
                            Command="{Binding NewProxyCommand}"
                            Padding="14,7"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5" />
                    <Button Content="Edit"
                            AutomationProperties.AutomationId="EditProxyButton"
                            Command="{Binding EditProxyCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding IsEditMode}" />
                    <Button Content="Check"
                            AutomationProperties.AutomationId="TestProxyButton"
                            Command="{Binding TestProxyCommand}"
                            Padding="14,7"
                            Background="#132D47"
                            Foreground="#4FA8FF"
                            BorderBrush="#1F5C92"
                            BorderThickness="1"
                            CornerRadius="5"
                            IsEnabled="{Binding IsEditMode}" />
                    <Button Content="Delete"
                            AutomationProperties.AutomationId="DeleteProxyButton"
                            Command="{Binding DeleteProxyCommand}"
                            Padding="14,7"
                            Background="#A33A3A"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding IsEditMode}" />
                    <Button Content="Refresh"
                            AutomationProperties.AutomationId="ProxiesRefreshButton"
                            Command="{Binding RefreshCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1"
                  AutomationProperties.AutomationId="ProxiesList"
                  ItemsSource="{Binding Proxies}"
                  SelectedItem="{Binding SelectedProxy}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  Background="#1E1E1E"
                  Foreground="#CCCCCC"
                  BorderBrush="#3E3E42"
                  RowBackground="#1E1E1E"
                  HeadersVisibility="Column"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="42">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ProxyItemViewModel">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="5"
                                    Background="{Binding StatusColor}"
                                    BorderBrush="{Binding StatusBorderColor}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="{Binding ValidationMessage}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Name" Binding="{Binding Proxy.Name}" Width="2*" />
                <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="120" />
                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="2*" />
                <DataGridTextColumn Header="Login" Binding="{Binding AuthDisplay}" Width="160" />
                <DataGridTextColumn Header="Status" Binding="{Binding ValidationMessage}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap">
                <Run Text="Status: " />
                <Run Text="{Binding StatusMessage}" />
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
