<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:YellowFox.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:Class="YellowFox.Desktop.Views.BookmarksView"
             x:DataType="vm:BookmarksViewModel"
             Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Background="#2D2D2D"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                    <Button AutomationProperties.AutomationId="NewBookmarkButton"
                            Content="New Bookmark"
                            Command="{Binding NewBookmarkCommand}"
                            Padding="14,7"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5" />
                    <Button AutomationProperties.AutomationId="NewFolderButton"
                            Content="New Folder"
                            Command="{Binding NewFolderCommand}"
                            Padding="14,7"
                            Background="#357ABD"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5" />
                    <Button AutomationProperties.AutomationId="EditBookmarkButton"
                            Content="Edit"
                            Command="{Binding EditBookmarkCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding IsEditMode}" />
                    <Button AutomationProperties.AutomationId="DeleteBookmarkButton"
                            Content="Delete"
                            Command="{Binding DeleteCommand}"
                            Padding="14,7"
                            Background="#A33A3A"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding IsEditMode}" />
                    <Button AutomationProperties.AutomationId="BookmarksRefreshButton"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding CurrentLevel}"
                           Foreground="#9E9E9E"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="16,0,0,0" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#1E1E1E"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1">
            <TreeView AutomationProperties.AutomationId="BookmarksTree"
                      ItemsSource="{Binding Bookmarks}"
                      SelectedItem="{Binding SelectedBookmark}"
                      Background="#1E1E1E"
                      Foreground="#CCCCCC"
                      Padding="12">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate DataType="vm:BookmarkNodeViewModel" ItemsSource="{Binding Children}">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10"
                              MinHeight="42"
                              Margin="4,3">
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="18"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#DDDDDD"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Url}"
                                           IsVisible="{Binding HasUrl}"
                                           Foreground="#858585"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Kind}"
                                       Foreground="#858585"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <Border Grid.Row="2"
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap">
                <Run Text="Status: " />
                <Run Text="{Binding StatusMessage}" />
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
