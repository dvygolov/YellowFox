<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:YellowFox.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:Class="YellowFox.Desktop.Views.ExtensionsView"
             x:DataType="vm:ExtensionsViewModel"
             Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Background="#2D2D2D"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button AutomationProperties.AutomationId="NewExtensionButton"
                            Content="New"
                            Command="{Binding NewExtensionCommand}"
                            Padding="14,7"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5" />
                    <Button AutomationProperties.AutomationId="EditExtensionButton"
                            Content="Edit"
                            Command="{Binding EditExtensionCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding HasSelection}" />
                    <Button AutomationProperties.AutomationId="ImportExtensionArchiveButton"
                            Content="Import Archive"
                            Command="{Binding ImportArchiveCommand}"
                            Padding="14,7"
                            Background="#235A8F"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5" />
                    <Button AutomationProperties.AutomationId="ToggleExtensionEnabledButton"
                            Content="Toggle"
                            Command="{Binding ToggleEnabledCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding HasSelection}" />
                    <Button AutomationProperties.AutomationId="DeleteExtensionButton"
                            Content="Delete"
                            Command="{Binding DeleteSelectedCommand}"
                            Padding="14,7"
                            Background="#A33A3A"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="5"
                            IsEnabled="{Binding HasSelection}" />
                    <Button AutomationProperties.AutomationId="ExtensionsRefreshButton"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="14,7"
                            Background="#3E3E42"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            CornerRadius="5" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1"
                  AutomationProperties.AutomationId="ExtensionsList"
                  ItemsSource="{Binding Extensions}"
                  SelectedItem="{Binding SelectedExtension}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  Background="#1E1E1E"
                  Foreground="#CCCCCC"
                  BorderBrush="#3E3E42"
                  RowBackground="#1E1E1E"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Extension" Width="260">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ExtensionItemViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="28"
                                        Height="28"
                                        CornerRadius="5"
                                        Background="#34373C"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Image Source="{Binding Icon}"
                                               Width="22"
                                               Height="22"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding HasIcon}" />
                                        <TextBlock Text="{Binding Initial}"
                                                   Foreground="#CCCCCC"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasNoIcon}" />
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <TextBlock Foreground="#AAAAAA" TextWrapping="Wrap">
                <Run Text="Status: " />
                <Run Text="{Binding StatusMessage}" />
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
