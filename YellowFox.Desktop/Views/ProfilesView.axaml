<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:YellowFox.Desktop.ViewModels"
             xmlns:converters="using:YellowFox.Desktop.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="YellowFox.Desktop.Views.ProfilesView"
             x:DataType="vm:ProfilesViewModel"
             Background="#1E1E1E">
    
    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="StatusColorConverter" />
    </UserControl.Resources>
    
    <UserControl.Styles>
        <Style Selector="Button.PrimaryAction">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="68" />
        </Style>
        <Style Selector="Button.PrimaryAction:pointerover">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.SecondaryAction">
            <Setter Property="Background" Value="#2E3132" />
            <Setter Property="BorderBrush" Value="#3E3E42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.SecondaryAction:pointerover">
            <Setter Property="Background" Value="#3A3E40" />
            <Setter Property="BorderBrush" Value="#5A5F63" />
        </Style>
    </UserControl.Styles>
    
    <DockPanel>
        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" 
                Background="#2D2D2D" 
                BorderBrush="#3E3E42" 
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <!-- Left: New Profile Button -->
                <Button Grid.Column="0"
                        AutomationProperties.AutomationId="NewProfileButton"
                        Content="➕ New Profile" 
                        Command="{Binding NewProfileCommand}"
                        Padding="16,8"
                        FontWeight="SemiBold"
                        Background="#4CAF50"
                        Foreground="White"
                        CornerRadius="6"
                        BorderThickness="0" />
                
                <!-- Center: Search Box -->
                <TextBox Grid.Column="1"
                         AutomationProperties.AutomationId="ProfilesSearchInput"
                         Width="400"
                         Margin="20,0"
                         Watermark="🔍 Search profiles..." 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="12,8"
                         Background="#252526"
                         Foreground="#CCCCCC"
                         BorderBrush="#3E3E42"
                         CornerRadius="6" />
                
                <!-- Right: Refresh Button -->
                <Button Grid.Column="2"
                        AutomationProperties.AutomationId="ProfilesRefreshButton"
                        Content="🔄 Refresh" 
                        Command="{Binding RefreshCommand}"
                        Padding="12,8"
                        Background="#3E3E42"
                        Foreground="#CCCCCC"
                        BorderThickness="0"
                        CornerRadius="6"
                        Margin="0,0,10,0" />
            </Grid>
        </Border>
        
        <!-- Table Header -->
        <Border DockPanel.Dock="Top"
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid ColumnDefinitions="36,20,300,170,*,Auto">
                <TextBlock Grid.Column="1" Text="" Foreground="#858585" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="Name" Foreground="#858585" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="Proxy" Foreground="#858585" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="Notes" Foreground="#858585" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="5" Text="Actions" Foreground="#858585" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
        </Border>
        
        <!-- Bottom Action Bar (Bulk Actions) - MUST BE BEFORE ScrollViewer -->
        <Border DockPanel.Dock="Bottom"
                Background="#2A2D2E"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="20,15"
                IsVisible="{Binding HasSelection}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="12">
                <!-- Selection Count -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCount}" 
                               Foreground="#CCCCCC"
                               FontWeight="SemiBold"
                               FontSize="14" />
                    <TextBlock Text="profile(s) selected" 
                               Foreground="#858585"
                               FontSize="14" />
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <!-- Start All Button -->
                    <Button Content="▶ START ALL" 
                            Command="{Binding StartAllSelectedCommand}"
                            Background="Transparent"
                            Foreground="#4CAF50"
                            BorderBrush="#4CAF50"
                            BorderThickness="1"
                            Padding="24,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            CornerRadius="6" />
                    
                    <!-- Delete All Button -->
                    <Button Content="🗑️ DELETE ALL" 
                            Command="{Binding DeleteAllSelectedCommand}"
                            Background="Transparent"
                            Foreground="#F44336"
                            BorderBrush="#F44336"
                            BorderThickness="1"
                            Padding="24,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            CornerRadius="6" />
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Profiles Table -->
        <ListBox ItemsSource="{Binding Profiles}"
                 AutomationProperties.AutomationId="ProfilesList"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:ProfileItemViewModel">
                    <!-- Profile Row -->
                    <Border Background="#252526"
                            BorderBrush="#3E3E42"
                            BorderThickness="0,0,0,1"
                            Padding="20,16"
                            HorizontalAlignment="Stretch">
                        <Border.Styles>
                            <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="#2D2D30" />
                            </Style>
                        </Border.Styles>
                        
                        <Grid ColumnDefinitions="36,20,300,170,*,Auto"
                              HorizontalAlignment="Stretch">
                                <!-- Checkbox Column -->
                                <CheckBox Grid.Column="0" 
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected}" />
                                
                                <!-- Status Indicator -->
                                <Ellipse Grid.Column="1"
                                         Width="10" Height="10"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Left"
                                         Fill="{Binding IsRunning, Converter={StaticResource StatusColorConverter}}" />
                                
                                <!-- Name with Icon -->
                                <StackPanel Grid.Column="2" 
                                            Orientation="Horizontal" 
                                            Spacing="10"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="💻" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Profile.Name}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"
                                               Foreground="#CCCCCC"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="220" />
                                </StackPanel>
                                
                                <!-- Proxy -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ProxyDisplay}" 
                                           Foreground="#858585"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Notes -->
                                <TextBlock Grid.Column="4"
                                           Text="{Binding NotesDisplay}"
                                           Foreground="#858585"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                
                                <!-- Action Buttons -->
                                <StackPanel Grid.Column="5"
                                            Orientation="Horizontal" 
                                            Spacing="6"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                    
                                    <!-- Start Button (when not running) -->
                                    <Button Classes="PrimaryAction"
                                            Content="Start" 
                                            Command="{Binding StartCommand}"
                                            IsVisible="{Binding IsNotRunning}"
                                            Background="#2E7D32" />
                                    
                                    <!-- Stop Button (when running) -->
                                    <Button Classes="PrimaryAction"
                                            Content="Stop" 
                                            Command="{Binding StopCommand}"
                                            IsVisible="{Binding IsRunning}"
                                            Background="#B71C1C" />
                                    
                                    <!-- Edit Button -->
                                    <Button Classes="SecondaryAction"
                                            Content="&#xE70F;" 
                                            Command="{Binding EditCommand}"
                                            ToolTip.Tip="Edit" />
                                    
                                    <!-- Clone Button -->
                                    <Button Classes="SecondaryAction"
                                            Content="&#xE8C8;" 
                                            Command="{Binding CloneCommand}"
                                            ToolTip.Tip="Clone" />

                                    <!-- Export Cookies -->
                                    <Button Classes="SecondaryAction"
                                            Content="&#xE896;" 
                                            Command="{Binding ExportCookiesCommand}"
                                            ToolTip.Tip="Export Cookies" />

                                    <!-- Import Cookies -->
                                    <Button Classes="SecondaryAction"
                                            Content="&#xE898;" 
                                            Command="{Binding ImportCookiesCommand}"
                                            ToolTip.Tip="Import Cookies" />

                                    <!-- View Log -->
                                    <Button Classes="SecondaryAction"
                                            Content="&#xE8A5;"
                                            Command="{Binding ViewLogCommand}"
                                            ToolTip.Tip="Open Profile Log" />
                                    
                                    <!-- Delete Button -->
                                    <Button Classes="SecondaryAction"
                                            Content="&#xE74D;" 
                                            Command="{Binding DeleteCommand}"
                                            Foreground="#F44336"
                                            ToolTip.Tip="Delete" />
                                </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Empty State -->
        <Panel IsVisible="{Binding !Profiles.Count}">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Spacing="15">
                <TextBlock Text="📁" 
                           FontSize="48" 
                           HorizontalAlignment="Center" />
                <TextBlock Text="No profiles yet" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Click 'New Profile' to create your first profile" 
                           Foreground="#858585"
                           FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Panel>
    </DockPanel>
    
</UserControl>
