<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:YellowFox.Desktop.ViewModels"
             xmlns:converters="using:YellowFox.Desktop.Converters"
             xmlns:behaviors="using:YellowFox.Desktop.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="YellowFox.Desktop.Views.ProfilesView"
             x:DataType="vm:ProfilesViewModel"
             Background="#1E1E1E">
    
    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="StatusColorConverter" />
    </UserControl.Resources>
    
    <UserControl.Styles>
        <Style Selector="Button.PrimaryAction">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="84" />
        </Style>
        <Style Selector="Button.PrimaryAction:pointerover">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.SecondaryAction">
            <Setter Property="Background" Value="#2E3132" />
            <Setter Property="BorderBrush" Value="#3E3E42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.SecondaryAction:pointerover">
            <Setter Property="Background" Value="#3A3E40" />
            <Setter Property="BorderBrush" Value="#5A5F63" />
        </Style>
        <Style Selector="TextBox.ProfileNotesTextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#B6BDC4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="#B6BDC4" />
            <Setter Property="SelectionBrush" Value="#315E96" />
        </Style>
        <Style Selector="Button.NotesToggle">
            <Setter Property="Background" Value="#34383C" />
            <Setter Property="BorderBrush" Value="#4A5158" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#D0D6DC" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.NotesHost:pointerover Button.NotesToggle">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.NotesToggle:pointerover">
            <Setter Property="Background" Value="#3E454B" />
            <Setter Property="BorderBrush" Value="#69737C" />
        </Style>
    </UserControl.Styles>
    
    <DockPanel>
        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" 
                Background="#2D2D2D" 
                BorderBrush="#3E3E42" 
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <!-- Left: New Profile Button -->
                <Button Grid.Column="0"
                        AutomationProperties.AutomationId="NewProfileButton"
                        Content="➕ New Profile" 
                        Command="{Binding NewProfileCommand}"
                        Padding="16,8"
                        FontWeight="SemiBold"
                        Background="#4CAF50"
                        Foreground="White"
                        CornerRadius="6"
                        BorderThickness="0" />
                
                <!-- Center: Search Box -->
                <TextBox Grid.Column="1"
                         AutomationProperties.AutomationId="ProfilesSearchInput"
                         Width="400"
                         Margin="20,0"
                         Watermark="🔍 Search profiles..." 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="12,8"
                         Background="#252526"
                         Foreground="#CCCCCC"
                         BorderBrush="#3E3E42"
                         CornerRadius="6" />
                
                <!-- Right: Refresh Button -->
                <Button Grid.Column="2"
                        AutomationProperties.AutomationId="ProfilesRefreshButton"
                        Content="🔄 Refresh" 
                        Command="{Binding RefreshCommand}"
                        Padding="12,8"
                        Background="#3E3E42"
                        Foreground="#CCCCCC"
                        BorderThickness="0"
                        CornerRadius="6"
                        Margin="0,0,10,0" />
            </Grid>
        </Border>
        
        <!-- Bottom Action Bar (Bulk Actions) - MUST BE BEFORE ScrollViewer -->
        <Border DockPanel.Dock="Bottom"
                Background="#2A2D2E"
                BorderBrush="#3E3E42"
                BorderThickness="0,1,0,0"
                Padding="20,15"
                IsVisible="{Binding HasSelection}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="12">
                <!-- Selection Count -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCount}" 
                               Foreground="#CCCCCC"
                               FontWeight="SemiBold"
                               FontSize="14" />
                    <TextBlock Text="profile(s) selected" 
                               Foreground="#858585"
                               FontSize="14" />
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <!-- Start All Button -->
                    <Button Content="▶ START ALL" 
                            Command="{Binding StartAllSelectedCommand}"
                            Background="Transparent"
                            Foreground="#4CAF50"
                            BorderBrush="#4CAF50"
                            BorderThickness="1"
                            Padding="24,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            CornerRadius="6" />
                    
                    <!-- Delete All Button -->
                    <Button Content="🗑️ DELETE ALL" 
                            Command="{Binding DeleteAllSelectedCommand}"
                            Background="Transparent"
                            Foreground="#F44336"
                            BorderBrush="#F44336"
                            BorderThickness="1"
                            Padding="24,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            CornerRadius="6" />
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Profiles Table -->
        <DataGrid x:Name="ProfilesDataGrid"
                  ItemsSource="{Binding Profiles}"
                  AutomationProperties.AutomationId="ProfilesList"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  Background="#1E1E1E"
                  Foreground="#CCCCCC"
                  BorderBrush="#3E3E42"
                  RowBackground="#252526"
                  HeadersVisibility="Column"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  CanUserResizeColumns="True"
                  behaviors:DataGridColumnWidthPersistence.Key="Profiles">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="36" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ProfileItemViewModel">
                            <CheckBox VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      IsChecked="{Binding IsSelected}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="" Width="28" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ProfileItemViewModel">
                            <Ellipse Width="10"
                                     Height="10"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center"
                                     Fill="{Binding IsRunning, Converter={StaticResource StatusColorConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Name" Width="240" SortMemberPath="Profile.Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ProfileItemViewModel">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10"
                                        VerticalAlignment="Center">
                                <Grid Width="28"
                                      Height="24"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="{Binding OsIconTip}">
                                    <Viewbox Width="{Binding OsIconBoxSize}"
                                             Height="{Binding OsIconBoxSize}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Stretch="Uniform">
                                        <Path Width="24"
                                              Height="24"
                                              Stretch="Uniform"
                                              Data="{Binding OsIconData}"
                                              Fill="{Binding OsIconFill}" />
                                    </Viewbox>
                                </Grid>
                                <TextBlock Text="{Binding Profile.Name}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Proxy"
                                    Binding="{Binding ProxyDisplay}"
                                    Width="150" />

                <DataGridTemplateColumn Header="Notes" Width="*" SortMemberPath="NotesDisplay">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ProfileItemViewModel">
                            <Border Classes="NotesHost"
                                    Background="#202326"
                                    BorderBrush="#30363D"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="0"
                                    Margin="0,4,12,4"
                                    VerticalAlignment="Center">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Classes="ProfileNotesTextBox"
                                             Text="{Binding NotesDisplay}"
                                             IsReadOnly="True"
                                             IsVisible="{Binding IsNotesCollapsed}"
                                             Height="34"
                                             TextWrapping="NoWrap"
                                             AcceptsReturn="False"
                                             VerticalContentAlignment="Center"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled" />

                                    <TextBox Grid.Column="0"
                                             Classes="ProfileNotesTextBox"
                                             Text="{Binding NotesDisplay}"
                                             IsReadOnly="True"
                                             IsVisible="{Binding IsNotesExpanded}"
                                             MinHeight="70"
                                             MaxHeight="190"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />

                                    <Button Grid.Column="1"
                                            Classes="NotesToggle"
                                            Content="{Binding NotesToggleIcon}"
                                            Command="{Binding ToggleNotesCommand}"
                                            IsVisible="{Binding HasNotes}"
                                            ToolTip.Tip="{Binding NotesToggleTip}"
                                            Margin="6,3,6,3"
                                            VerticalAlignment="Top" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Actions" Width="180" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ProfileItemViewModel">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                <Button Classes="PrimaryAction"
                                        Command="{Binding StartCommand}"
                                        IsVisible="{Binding IsStartActionVisible}"
                                        Background="#2E7D32">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                                        <TextBlock Text="Start" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Classes="PrimaryAction"
                                        Command="{Binding StopCommand}"
                                        IsVisible="{Binding IsRunningActionVisible}"
                                        Background="#B71C1C">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                                        <TextBlock Text="Stop" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Classes="PrimaryAction"
                                        IsVisible="{Binding IsImportingCookies}"
                                        IsEnabled="False"
                                        Background="#235A8F">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                                        <TextBlock Text="Importing" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Classes="SecondaryAction"
                                        Content="&#xE712;"
                                        ToolTip.Tip="More actions">
                                    <Button.Flyout>
                                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                                            <MenuItem Header="Edit" Command="{Binding EditCommand}" />
                                            <MenuItem Header="Clone" Command="{Binding CloneCommand}" />
                                            <MenuItem Header="Export cookies" Command="{Binding ExportCookiesCommand}" />
                                            <MenuItem Header="Import cookies" Command="{Binding ImportCookiesCommand}" />
                                            <MenuItem Header="Open log" Command="{Binding ViewLogCommand}" />
                                            <MenuItem Header="Delete" Command="{Binding DeleteCommand}" Foreground="#F44336" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Empty State -->
        <Panel IsVisible="{Binding !Profiles.Count}">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Spacing="15">
                <TextBlock Text="📁" 
                           FontSize="48" 
                           HorizontalAlignment="Center" />
                <TextBlock Text="No profiles yet" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Click 'New Profile' to create your first profile" 
                           Foreground="#858585"
                           FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Panel>
    </DockPanel>
    
</UserControl>
